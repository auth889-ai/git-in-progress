# Server port (defaults to 3000 if not set)
PORT=3002

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/githubclone

# Secret used to sign JWT tokens
JWT_SECRET_KEY=your_jwt_secret_here

# Backblaze B2 (S3-compatible) storage for CLI push/pull — OPTIONAL.
# If these are missing, push/pull automatically falls back to MongoDB GridFS.
# B2_KEY_ID=your_full_keyID_from_the_application_keys_page
# B2_APPLICATION_KEY=your_application_key
# B2_BUCKET=your_bucket_name
# B2_REGION=us-east-005
# B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
